<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />

    <!--
        Sprint 29b: enableOnBackInvokedCallback="true" opts the app into
        Android 14+'s predictive back gesture framework. Navigation Compose
        2.8.5 hooks its own OnBackInvokedCallback into the dispatcher's
        callback list and drives the per-destination scale animation
        natively. Setting the flag at the <application> level affects
        every Activity (currently just MainActivity + HandyInputMethodService
        + RecordingService, the latter two never reach user-facing back
        gestures because they aren't focusable activities). The flag is a
        no-op on Android 13 and below — legacy onBackPressed handling
        remains in effect via ComponentActivity. Predictive-back visual
        feedback (system-rendered scale-down animation during the
        gesture) only activates on API 34+ devices with this flag set.        IMPORTANT DEVIATION FROM USER BRIEF: The Sprint 29b brief asked for
        "PredictiveBackHandler integration en MainActivity.kt". This flag
        is the canonical — and minimal — implementation path. Navigation
        Compose 2.8.5 handles predictive-back gestures natively once the
        flag is set, so adding composable-level PredictiveBackHandler calls
        would (a) DUPLICATE the gesture handling, (b) suppress the
        Compose Navigation destination-level scale animation and force us
        to drive our own per-destination animation via Flow<BackEventCompat>,
        AND (c) require us to wrap each composable(...) body in a
        Box+Modifier.scale(progress) wrapper — re-introducing the broader
        "defensive layout wrapper around each destination body" pattern
        that Sprint 28b-v8 through v15 explicitly closed to keep Compose
        Layout's measure-pass predictable. Therefore the canonical
        implementation is the single manifest attribute, and Kotlin-level
        handlers would strictly make things worse by re-introducing the
        defensive-wrapper pattern the v8–v15 chain eliminated.

        Note on scope: When the IME pill is invoked against MainActivity's
        own text fields (e.g., paste-back into our own Settings screens),
        back-press routes to MainActivity — the only focusable Activity in
        the app — and the flag applies. When the IME pill is invoked
        against a third-party client (Messages, WhatsApp, etc.), back-press
        routes to that client app and our flag has no effect on that
        gesture. Setting the flag at <application> covers the in-app scope
        correctly; per-Activity scoping would also work but is redundant
        when only one focusable Activity exists....
    -->
    <application
        android:name=".HandyApplication"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Handy">

        <meta-data
            android:name="io.sentry.auto-init"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|locale|layoutDirection|density|fontScale">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ime.HandyInputMethodService"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <service
            android:name=".service.RecordingService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!--
            Test-only receiver for ADB automation. Disabled in release builds via
            manifest placeholder and guarded at runtime by BuildConfig.DEBUG.
        -->
        <receiver
            android:name=".TestCommandReceiver"
            android:exported="true"
            android:permission="android.permission.DUMP"
            android:enabled="${debugReceiverEnabled}">
            <intent-filter>
                <action android:name="com.handy.app.action.DOWNLOAD_MODEL" />
                <action android:name="com.handy.app.action.SET_ACTIVE_MODEL" />
                <action android:name="com.handy.app.action.SEED_HISTORY" />
                <action android:name="com.handy.app.action.SET_DEBUG_MODE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
