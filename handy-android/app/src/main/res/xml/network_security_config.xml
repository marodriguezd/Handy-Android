<?xml version="1.0" encoding="utf-8"?>
<!--
    Sprint 26 — Network security config for the Post-Process destination.

    Strategy (per the in-session thinker pass): per-domain cleartext
    allowance for the two specific loopback hosts the user actually
    needs in dev/local-emulator:

      * 10.0.2.2 — the Android emulator's loopback to the host
        machine (Ollama dev-default listens here).
      * localhost — qemu user-net bridge; Docker-for-Mac / WSL /
        some podman setups expose Ollama at this address.

    Both apply in debug AND release — verified by the build target.
    Everything else continues to require HTTPS via the system default
    cleartextTrafficPermitted="false". This is the safest scope that
    still lets users run Ollama locally without weakening security on
    arbitrary external domains.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
