<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground for Handy (Speech-to-Text / Whisper transcription).

    Viewport is 108×108 dp (per Android adaptive-icon spec). All artwork fits in the
    72dp safe zone (y=18..90 of the 108dp viewbox); the outer 18dp on each side is the
    clip-zone and may be cropped by squircle / circular / teardrop launcher masks.

    Single-color (white) so the same vector is valid for both:
      - <foreground> rendered as-is against the @color/primary pink background, and
      - <monochrome> which Android 13+ tints with the active theme color when the
        user enables Themed Icons (Material You / One UI).

    Geometry (108-scale coordinates):
      - Mic capsule body:   rounded rect (42,20)→(66,56), rx=12 (stadium shape)
      - Stand U-arc:        left+right verticals y=56..64 + bottom arc (rx=24, ry=12)
                            reaching y=76
      - Stem:               x=54, y=76..86
      - Base:               x=44..64, y=86 (stroke-width=4 → occupies y=84..88).
                            Shy of the 72dp safe-zone bottom edge so aggressive
                            launcher masks (Pixel squircle, One UI teardrop) cannot
                            shave the round line-caps off the bar.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 1. Mic capsule body (stadium / capsule shape, white fill). -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M48,20 H60 A12,12 0 0,1 66,32 V44 A12,12 0 0,1 60,56 H48 A12,12 0 0,1 42,44 V32 A12,12 0 0,1 48,20 Z" />

    <!-- 2. Stand U-arc (stroke; verticals + bottom half-ellipse open downward). -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M30,56 V64 A24,12 0 0,1 78,64 V56" />

    <!-- 3. Stem (vertical stroke, x=54, y=76 → y=86). -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M54,76 V86" />

    <!-- 4. Base bar (horizontal stroke, y=86, x=44..64).
            stroke-width=4 with round caps renders the bar from y=84..88, giving
            crisp connection to the stem (whose endpoint lands at y=86 + 2 cap-radius
            = ~y=88, exactly overlapping the base stroke center). -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M44,86 H64" />
</vector>
