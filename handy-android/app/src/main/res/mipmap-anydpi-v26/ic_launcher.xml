<?xml version="1.0" encoding="utf-8"?>
<!--
    Handy adaptive icon (Android API 26+, minSdk=26).

    Three roles referenced here:
      - <background>  Solid Handy pink (#f28cbb, seed) on the 108×108 viewport.
      - <foreground>  White mic-glyph vector (drawable/ic_launcher_foreground.xml),
                      clipped by the launcher mask, content fits the 72dp safe zone.
      - <monochrome>  Same vector, used by Android 13+ when the user enables Themed
                      Icons (Material You / One UI). The system re-tints the
                      silhouette with the user's theme color.

    The duplicate ic_launcher_round.xml has been removed: with a single adaptive
    icon, the system applies the requested mask shape (round / squircle /
    teardrop / circle) automatically. AndroidManifest.xml points both
    android:icon and android:roundIcon to this same @mipmap/ic_launcher resource.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/primary" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
